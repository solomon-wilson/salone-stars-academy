# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (used for CORS in production).
APP_URL="MY_APP_URL"

# Deployment mode: pi | cloud | hybrid (default: pi, or hybrid when FIREBASE_PROJECT_ID is set)
DEPLOYMENT_MODE=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase configuration (server-side Admin SDK + cloud sync)
FIREBASE_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_MEASUREMENT_ID=
