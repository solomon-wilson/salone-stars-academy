# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (used for CORS in production).
APP_URL="MY_APP_URL"

# Deployment mode: pi | cloud | hybrid (default: pi, or hybrid when FIREBASE_PROJECT_ID is set)
DEPLOYMENT_MODE=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase configuration (server-side Admin SDK + cloud sync)
FIREBASE_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_MEASUREMENT_ID=

# Redis (rate limiting + token cache in cloud; optional for Pi offline)
REDIS_URL=

# CORS: comma-separated origins for institutional browser clients
INTEGRATION_ORIGINS=

# MCP server (packages/ssa-mcp-server)
MCP_SSE_PORT=3100
MCP_SSE_API_KEY=
MCP_TRANSPORT=
SSA_API_URL=http://localhost:3000
SSA_API_KEY=
SSA_FIREBASE_TOKEN=
