rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function hasUniqueBadges(badges) {
      return badges is list && badges.size() <= 32;
    }

    function isMonotonicDate(incomingDate, existingDate) {
      return incomingDate is string && incomingDate >= existingDate;
    }

    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasPremiumPlan() {
      let profile = getUserProfile();
      return isSignedIn() && (
        profile.subscriptionPlan == "individual" ||
        profile.subscriptionPlan == "team"
      );
    }

    function hasTeacherPremiumPlan() {
      let profile = getUserProfile();
      return isSignedIn() &&
        profile.get('role', '') == 'teacher' &&
        (profile.get('subscriptionPlan', '') == 'individual' ||
         profile.get('subscriptionPlan', '') == 'team');
    }

    function hasParentPremiumPlan() {
      let profile = getUserProfile();
      return isSignedIn() &&
        profile.get('role', '') == 'parent' &&
        (profile.get('subscriptionPlan', '') == 'individual' ||
         profile.get('subscriptionPlan', '') == 'team');
    }

    function hasValidPupilOwner(data) {
      return (data.get('teacherId', '') is string && data.teacherId.size() > 0 && data.teacherId.size() <= 128)
        || (data.get('parentId', '') is string && data.parentId.size() > 0 && data.parentId.size() <= 128);
    }

    function isPupilAuthority(data) {
      return data.get('teacherId', '') == request.auth.uid
        || data.get('parentId', '') == request.auth.uid
        || data.id == request.auth.uid;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 128 &&
             data.role in ["teacher", "pupil", "parent"] &&
             data.subscriptionPlan in ["free", "individual", "team"] &&
             (!('whatsappPhone' in data) || (data.whatsappPhone is string && data.whatsappPhone.size() <= 20)) &&
             (!('digestOptIn' in data) || data.digestOptIn is bool);
    }

    function isValidPupil(data) {
      return isValidId(data.id) &&
             data.name is string && data.name.size() <= 128 &&
             data.class_level is string && data.class_level.size() <= 64 &&
             data.points is int && data.points >= 0 &&
             data.streak_count is int && data.streak_count >= 0 &&
             hasValidPupilOwner(data) &&
             hasUniqueBadges(data.get('badges_earned', []));
    }

    function isValidQuest(data) {
      return isValidId(data.id) &&
             data.title is string && data.title.size() <= 256 &&
             data.subject is string && data.subject.size() <= 128 &&
             data.class_level is string && data.class_level.size() <= 64 &&
             data.points_award is int && data.points_award >= 0 &&
             data.source in ["default", "generated"];
    }

    function isValidCurriculum(data) {
      return isValidId(data.id) &&
             data.teacherId is string && data.teacherId.size() <= 128 &&
             data.class_level is string && data.class_level.size() <= 64 &&
             data.alignedMbsseOutcome is string && data.alignedMbsseOutcome.size() <= 512 &&
             data.topics is list && data.topics.size() <= 32;
    }

    function isValidParentNote(data) {
      return data.parentId is string && data.parentId.size() <= 128 &&
             data.weekKey is string && data.weekKey.size() <= 32 &&
             data.topics is string && data.topics.size() <= 500 &&
             data.updatedAt is string && data.updatedAt.size() <= 64;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) &&
        incoming().subscriptionPlan == "free" &&
        incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
        incoming().uid == existing().uid &&
        incoming().role == existing().role &&
        incoming().createdAt == existing().createdAt &&
        incoming().subscriptionPlan == existing().subscriptionPlan &&
        incoming().stripeCustomerId == existing().stripeCustomerId &&
        incoming().stripeSubscriptionStatus == existing().stripeSubscriptionStatus;
    }

    match /pupils/{pupilId} {
      allow get: if isSignedIn() && isValidId(pupilId) && isPupilAuthority(existing());
      allow list: if false;
      allow create: if isSignedIn() && isValidId(pupilId) && isValidPupil(incoming()) &&
        (incoming().teacherId == request.auth.uid || incoming().parentId == request.auth.uid || incoming().id == request.auth.uid);
      allow update: if isSignedIn() && isValidId(pupilId) && isValidPupil(incoming()) &&
        isPupilAuthority(existing()) &&
        isMonotonicDate(
          incoming().get('last_active_date', existing().last_active_date),
          existing().get('last_active_date', '1970-01-01')
        );
      allow delete: if isSignedIn() && (
        existing().teacherId == request.auth.uid || existing().parentId == request.auth.uid
      );
    }

    match /quests/{questId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidId(questId) && isValidQuest(incoming()) &&
        incoming().teacherId == request.auth.uid &&
        incoming().source == "generated";
      allow update: if isSignedIn() && existing().teacherId == request.auth.uid &&
        incoming().source == existing().source;
      allow delete: if isSignedIn() && existing().teacherId == request.auth.uid;
    }

    match /curriculums/{curriculumId} {
      allow get: if isSignedIn() && existing().teacherId == request.auth.uid;
      allow list: if false;
      allow create: if hasTeacherPremiumPlan() && isValidId(curriculumId) &&
        isValidCurriculum(incoming()) && incoming().teacherId == request.auth.uid;
      allow update: if hasTeacherPremiumPlan() && isValidCurriculum(incoming()) &&
        existing().teacherId == request.auth.uid;
      allow delete: if hasTeacherPremiumPlan() && existing().teacherId == request.auth.uid;
    }

    match /parent_notes/{noteId} {
      allow get: if isSignedIn() && existing().parentId == request.auth.uid;
      allow list: if false;
      allow create: if hasParentPremiumPlan() && isValidParentNote(incoming()) &&
        incoming().parentId == request.auth.uid;
      allow update: if hasParentPremiumPlan() && isValidParentNote(incoming()) &&
        existing().parentId == request.auth.uid && incoming().parentId == request.auth.uid;
      allow delete: if isSignedIn() && existing().parentId == request.auth.uid &&
        getUserProfile().role == "parent";
    }

    // Server-only collections — Admin SDK writes via Express API
    match /api_keys/{keyId} {
      allow read, write: if false;
    }

    match /audit_logs/{logId} {
      allow read, write: if false;
    }

    match /webhooks/{webhookId} {
      allow read, write: if false;
    }

    match /webhook_logs/{logId} {
      allow read, write: if false;
    }
  }
}
