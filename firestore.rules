rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Zero Trust by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for auth state
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function hasUniqueBadges(badges) {
      return badges is list && badges.size() <= 32;
    }

    function isMonotonicDate(incomingDate, existingDate) {
      return incomingDate is string && incomingDate >= existingDate;
    }

    // Grab Teacher user profile from database to verify subscription state
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasPremiumPlan() {
      return isSignedIn() && (
        getUserProfile().subscriptionPlan == "individual" || 
        getUserProfile().subscriptionPlan == "team"
      );
    }

    // Strict validation schemas matching entities in firebase-blueprint.json
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 128 &&
             data.role in ["teacher", "pupil"] &&
             data.subscriptionPlan in ["free", "individual", "team"];
    }

    function isValidPupil(data) {
      return isValidId(data.id) &&
             data.name is string && data.name.size() <= 128 &&
             data.class_level is string && data.class_level.size() <= 64 &&
             data.points is int && data.points >= 0 &&
             data.streak_count is int && data.streak_count >= 0 &&
             data.teacherId is string && data.teacherId.size() <= 128 &&
             hasUniqueBadges(data.get('badges_earned', []));
    }

    function isValidQuest(data) {
      return isValidId(data.id) &&
             data.title is string && data.title.size() <= 256 &&
             data.subject is string && data.subject.size() <= 128 &&
             data.class_level is string && data.class_level.size() <= 64 &&
             data.points_award is int && data.points_award >= 0 &&
             data.source in ["default", "generated"];
    }

    function isValidCurriculum(data) {
      return isValidId(data.id) &&
             data.teacherId is string && data.teacherId.size() <= 128 &&
             data.class_level is string && data.class_level.size() <= 64 &&
             data.alignedMbsseOutcome is string && data.alignedMbsseOutcome.size() <= 512 &&
             data.topics is list && data.topics.size() <= 32;
    }

    // Rules for User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) &&
        incoming().subscriptionPlan == "free" &&
        incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
        incoming().uid == existing().uid &&
        incoming().role == existing().role &&
        incoming().createdAt == existing().createdAt &&
        // Block client self-service premium and Stripe field writes
        incoming().subscriptionPlan == existing().subscriptionPlan &&
        incoming().stripeCustomerId == existing().stripeCustomerId &&
        incoming().stripeSubscriptionStatus == existing().stripeSubscriptionStatus;
    }

    // Rules for Pupil performance
    match /pupils/{pupilId} {
      allow get: if isSignedIn() && isValidId(pupilId) && (
        existing().teacherId == request.auth.uid || existing().id == request.auth.uid
      );
      allow list: if false;
      allow create: if isSignedIn() && isValidId(pupilId) && isValidPupil(incoming()) &&
        (incoming().teacherId == request.auth.uid || incoming().id == request.auth.uid);
      allow update: if isSignedIn() && isValidId(pupilId) && isValidPupil(incoming()) && (
        existing().teacherId == request.auth.uid || existing().id == request.auth.uid
      ) && isMonotonicDate(
        incoming().get('last_active_date', existing().last_active_date),
        existing().get('last_active_date', '1970-01-01')
      );
      allow delete: if isSignedIn() && existing().teacherId == request.auth.uid;
    }

    // Rules for Quests
    match /quests/{questId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidId(questId) && isValidQuest(incoming()) &&
        incoming().teacherId == request.auth.uid &&
        incoming().source == "generated";
      allow update: if isSignedIn() && existing().teacherId == request.auth.uid &&
        incoming().source == existing().source;
      allow delete: if isSignedIn() && existing().teacherId == request.auth.uid;
    }

    // Rules for custom School Curriculums
    match /curriculums/{curriculumId} {
      allow get: if isSignedIn() && existing().teacherId == request.auth.uid;
      allow list: if false;
      allow create: if isSignedIn() && isValidId(curriculumId) && hasPremiumPlan() &&
        isValidCurriculum(incoming()) && incoming().teacherId == request.auth.uid;
      allow update: if isSignedIn() && hasPremiumPlan() && isValidCurriculum(incoming()) &&
        existing().teacherId == request.auth.uid;
      allow delete: if isSignedIn() && hasPremiumPlan() && existing().teacherId == request.auth.uid;
    }
  }
}
