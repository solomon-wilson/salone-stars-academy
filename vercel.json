{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:slug*", "destination": "/api/index" },
    { "source": "/_mock-payment", "destination": "/api/index" },
    { "source": "/:slug*", "destination": "/index.html" }
  ]
}
